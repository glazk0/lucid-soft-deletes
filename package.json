{
  "name": "@glazk0/lucid-soft-deletes",
  "description": "Laravel-style soft-delete mixin for AdonisJS Lucid v22",
  "version": "1.0.2",
  "engines": {
    "node": ">=24.0.0"
  },
  "type": "module",
  "files": [
    "build",
    "!build/bin",
    "!build/tests"
  ],
  "main": "build/index.js",
  "exports": {
    ".": {
      "types": "./build/index.d.ts",
      "import": "./build/index.js"
    },
    "./providers/soft_deletes_provider": {
      "types": "./build/providers/soft_deletes_provider.d.ts",
      "import": "./build/providers/soft_deletes_provider.js"
    },
    "./types": {
      "types": "./build/src/types.d.ts",
      "import": "./build/src/types.js"
    },
    "./commands": {
      "types": "./build/commands/main.d.ts",
      "import": "./build/commands/main.js"
    },
    "./commands/*": {
      "types": "./build/commands/*.d.ts",
      "import": "./build/commands/*.js"
    }
  },
  "scripts": {
    "copy:templates": "copyfiles \"stubs/**/*.stub\" build",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "format": "prettier --write .",
    "quick:test": "node --import=@poppinss/ts-exec --enable-source-maps bin/test.ts",
    "pretest": "npm run lint",
    "test": "c8 npm run quick:test",
    "precompile": "npm run lint",
    "compile": "tsdown && tsc --emitDeclarationOnly --declaration",
    "postcompile": "npm run copy:templates",
    "build": "npm run compile",
    "release": "release-it",
    "version": "npm run build",
    "prepublishOnly": "npm run build"
  },
  "author": "glazk0",
  "license": "MIT",
  "homepage": "https://github.com/glazk0/lucid-soft-deletes#readme",
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/glazk0/lucid-soft-deletes.git"
  },
  "bugs": {
    "url": "https://github.com/glazk0/lucid-soft-deletes/issues"
  },
  "keywords": [
    "adonisjs",
    "adonisjs-lucid",
    "adonisjs-lucid-soft-deletes",
    "adonisjs-soft-deletes",
    "adonis",
    "adonis-lucid",
    "adonis-lucid-soft-deletes",
    "adonis-soft-deletes"
  ],
  "dependencies": {
    "@poppinss/utils": "^7.0.1"
  },
  "devDependencies": {
    "@adonisjs/assembler": "^8.0.0",
    "@adonisjs/core": "^7.0.1",
    "@adonisjs/eslint-config": "^3.0.0",
    "@adonisjs/lucid": "^22.0.0",
    "@adonisjs/prettier-config": "^1.4.5",
    "@adonisjs/tsconfig": "^2.0.0",
    "@japa/assert": "^4.2.0",
    "@japa/runner": "^5.3.0",
    "@poppinss/hooks": "^7.0.0",
    "@poppinss/ts-exec": "^1.4.4",
    "@release-it/conventional-changelog": "^10.0.5",
    "@types/luxon": "^3.4.2",
    "@types/node": "^25.3.5",
    "c8": "^11.0.0",
    "copyfiles": "^2.4.1",
    "cross-env": "^10.1.0",
    "eslint": "^10.0.3",
    "luxon": "^3.5.0",
    "prettier": "^3.8.1",
    "release-it": "^19.2.4",
    "tsdown": "^0.21.0",
    "typescript": "^5.9.3"
  },
  "peerDependencies": {
    "@adonisjs/assembler": "^8.0.0",
    "@adonisjs/core": "^7.0.0",
    "@adonisjs/lucid": "^22.0.0",
    "@poppinss/hooks": "^7.0.0",
    "luxon": "^3.0.0"
  },
  "peerDependenciesMeta": {
    "@adonisjs/assembler": {
      "optional": true
    }
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "release-it": {
    "git": {
      "requireCleanWorkingDir": true,
      "requireUpstream": true,
      "commitMessage": "chore(release): ${version}",
      "tagAnnotation": "v${version}",
      "push": true,
      "tagName": "v${version}"
    },
    "github": {
      "release": true
    },
    "npm": {
      "publish": true,
      "skipChecks": true
    },
    "plugins": {
      "@release-it/conventional-changelog": {
        "preset": {
          "name": "angular"
        }
      }
    }
  },
  "c8": {
    "reporter": [
      "text",
      "html"
    ],
    "exclude": [
      "tests/**"
    ]
  },
  "prettier": "@adonisjs/prettier-config"
}
